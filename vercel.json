{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/ingest/rss",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/ingest/twitter?batch=1",
      "schedule": "0,15,30,45 * * * *"
    },
    {
      "path": "/api/ingest/twitter?batch=2",
      "schedule": "2,17,32,47 * * * *"
    },
    {
      "path": "/api/ingest/twitter?batch=3",
      "schedule": "4,19,34,49 * * * *"
    },
    {
      "path": "/api/ingest/reddit",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/ingest/prediction-market",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/ingest/prediction-market?category=Crypto",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/analyze",
      "schedule": "7,22,37,52 * * * *"
    },
    {
      "path": "/api/digest",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/attribution",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cleanup",
      "schedule": "0 8 * * *"
    }
  ]
}
